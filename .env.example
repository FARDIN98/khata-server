# Database (Neon pooled connection string — ends with -pooler.neon.tech)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DBNAME?sslmode=require

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Stripe (test mode — https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# App
PORT=3003
FRONTEND_ORIGIN=http://localhost:3000
NODE_ENV=development
